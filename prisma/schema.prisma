generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  githubId      String   @unique
  username      String   @unique
  avatar        String?
  bio           String?
  githubToken   String?
  
  // Profile Settings
  preferredLanguages   String  // e.g., '["TypeScript", "Python"]'
  preferredTopics      String  // e.g., '["AI", "Web3"]'
  experienceLevel      String    // "beginner" | "intermediate" | "advanced"
  
  // Gamification
  xp            Int      @default(0)
  rank          String   @default("New Contributor") // rank name
  dailyStreak   Int      @default(0)
  lastSwiped    DateTime?
  
  // Relations
  swipes        Swipe[]
  savedMatches  SavedMatch[]
  notifications Notification[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Repository {
  id            String   @id @default(cuid())
  githubId      String   @unique
  name          String
  owner         String
  fullName      String   @unique // "owner/name"
  url           String
  description   String?
  language      String?  // primary language
  languages     String // all languages in repo (JSON string)
  stars         Int      @default(0)
  license       String?
  readmeText    String?
  topics        String // (JSON string)
  
  // Issue tracking
  issues        Issue[]
  syncedAt      DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Issue {
  id            String   @id @default(cuid())
  githubId      String
  githubNumber  Int
  title         String
  description   String?
  url           String
  labels        String // e.g., '["good first issue", "help wanted"]'
  difficulty    String   @default("beginner") // "beginner" | "intermediate" | "advanced"
  commentsCount Int      @default(0)
  
  // Relation
  repositoryId  String
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  
  // Swipes on this issue
  swipes        Swipe[]
  savedMatches  SavedMatch[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([repositoryId, githubNumber])
}

model Swipe {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issueId       String
  issue         Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  
  direction     String   // "right" | "left" | "saved"
  matchScore    Int      // 0-100 score
  
  createdAt     DateTime @default(now())
  
  @@unique([userId, issueId])
}

model SavedMatch {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  issueId       String
  issue         Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  
  status        String   @default("bookmarked") // "bookmarked" | "pr_opened" | "pr_merged"
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, issueId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, MATCH
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}
